# Base de données Neon PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&channel_binding=require"
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST-direct/DB?sslmode=require&channel_binding=require"

# Auth JWT
JWT_SECRET="changez-ceci-en-production-minimum-32-caracteres"

# URL de l'app (sans slash final)
NEXT_PUBLIC_APP_URL="https://votre-domaine.vercel.app"

# Cloudinary (facultatif — upload images/audio/vidéo)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="cmd-upload"

# ID de l'église principale (côté SERVEUR uniquement — ne pas préfixer NEXT_PUBLIC_)
# Récupérez-le après npx tsx prisma/seed.ts (affiché dans le terminal)
MAIN_CHURCH_ID=""

# Affiché côté client pour pré-remplir le formulaire de don (peut être le même ID)
NEXT_PUBLIC_DEFAULT_CHURCH_ID=""

# Resend (newsletter)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="newsletter@votre-domaine.com"
